---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout title="Inscription">
  <section class="py-16">
    <div class="container">
      <div class="container">
      <div class="text-center mb-12">
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Vous trouverez ci-dessous le formulaire d'inscription.
        </p>
      </div>
    </div>
    <div class="container max-w-3xl mx-auto">
      <div class="mb-6">
        <object
          data="/uploads/inscriptions/DEMANDE-INSCRIPTION.pdf"
          type="application/pdf"
          width="100%"
          height="100%"
          class="w-full h-96 border rounded overflow-hidden"
        >
          <p>
            Your browser does not support PDFs.
            <a href="/uploads/inscriptions/DEMANDE-INSCRIPTION.pdf" target="_blank" rel="noopener">Download the PDF</a>.
          </p>
        </object>
        <p class="text-sm text-gray-600 mt-2">Vous pouvez télécharger le formulaire : <a href="/uploads/inscriptions/DEMANDE-INSCRIPTION.pdf" class="text-primary-600 underline" target="_blank" rel="noopener">Télécharger le PDF</a></p>
      </div>      
    </div>
  </section>
  <section class="py-16 bg-white">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Tout est prêt ?</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Rapprochez-vous de votre enseignant afin de lui envoyer ou apporter vos documents et annoncer votre venue !
        </p>
        <div class="flex flex-wrap justify-center gap-4 mt-8">
          <Button href="/contact" variant="outline" size="lg">Nous contacter</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
