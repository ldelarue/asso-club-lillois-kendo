---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
import Card from "../../components/UI/Card.astro";
import { getCollection } from "astro:content";
import { formatDate, isFutureDate, isPastDate } from "../../utils/dateUtils";

// Get all events
const allEvents = await getCollection("events", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Separate upcoming and past events (use `startDate`)
const upcomingEvents = allEvents.filter(event => isFutureDate(event.data.startDate))
                            .sort((a, b) => new Date(a.data.startDate).getTime() - new Date(b.data.startDate).getTime());

const pastEvents = allEvents.filter(event => isPastDate(event.data.startDate))
                        .sort((a, b) => new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime())
                        .slice(0, 6); // Show only the most recent past events
---

<BaseLayout
  title="Évènements"
>
  <PageHeader 
    title="Évènements" 
    subtitle="Rejoignez-nous pour ces activités à venir"
    backgroundImage="/uploads/evenements-headzer-bg.webp"
  />
  
  <!-- Upcoming Events -->
  <section class="py-16">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">À venir</h2>
      </div>
      
      {
        upcomingEvents.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {upcomingEvents.map((event) => (
              <Card
                title={event.data.title}
                image={{
                  src: event.data.image,
                  alt: event.data.title
                }}
                href={`/evenements/${event.slug}`}
              >
                <div class="mb-3 flex items-center text-gray-600 justify-between">
                  <div class="flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span>{formatDate(event.data.startDate)}</span>
                    {event.data.endDate && (
                      <span class="ml-1">- {formatDate(event.data.endDate)}</span>
                    )}
                  </div>
                </div>
                {event.data.time && (
                  <div class="mb-3 flex items-center text-gray-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                      <span>{event.data.time}</span>
                  </div>
                )}
                
                <div class="mb-3 flex items-center text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span>{event.data.location}</span>
                </div>
                
                <p class="text-gray-700 mb-4">{event.data.summary}</p>
                
                <p class="text-primary-600 font-medium group-hover:underline group-hover:text-primary-700">
                  En savoir plus →
                </p>
              </Card>
            ))}
          </div>
        ) : (
          <div class="text-center py-12 bg-white rounded-lg shadow-sm max-w-md mx-auto">
            <p class="text-gray-600">Aucun évènement à venir.</p>
          </div>
        )
      }
    </div>
  </section>
  
  <!-- Past Events -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Passés</h2>
      </div>
      
      {
        pastEvents.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {pastEvents.map((event) => (
              <Card
                title={event.data.title}
                image={{
                  src: event.data.image,
                  alt: event.data.title
                }}
                href={`/evenements/${event.slug}`}
                className="opacity-90 hover:opacity-100"
              >
                <div class="mb-3 flex items-center text-gray-600 justify-between">
                  <div class="flex items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span>{formatDate(event.data.startDate)}</span>
                    {event.data.endDate && (
                      <span class="ml-1"> - {formatDate(event.data.endDate)}</span>
                    )}
                  </div>
                </div>
                <div class="mb-3 flex items-center text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span>{event.data.location}</span>
                </div>
                
                <p class="text-gray-700 mb-4">{event.data.summary}</p>

                <p class="text-primary-600 font-medium group-hover:underline group-hover:text-primary-700">
                  Consulter →
                </p>
              </Card>
            ))}
          </div>
        ) : (
          <div class="text-center py-12 bg-white rounded-lg shadow-sm max-w-md mx-auto">
            <p class="text-gray-600">Aucun évènement passé à afficher.</p>
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
