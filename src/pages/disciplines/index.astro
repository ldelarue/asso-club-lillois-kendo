---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
import { getCollection } from "astro:content";
import Button from "../../components/UI/Button.astro";

// Fetch all disciplines
const all = await getCollection("disciplines", ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);
// Sort by order or name
const ministries = all.sort((a, b) =>
  (a.data.order ?? 0) - (b.data.order ?? 0) ||
  a.data.name.localeCompare(b.data.name)
);
---

<BaseLayout title="Nos disciplines" description="Quand on lui demanda combien de chemins mènent à l'illumination, le moine frappa dans un tas de sable. « Comptez, dit-il en souriant, et ajoutez d'autres grains. »">
  <PageHeader
    title="Nos disciplines" 
    subtitle="Quand on lui demanda combien de chemins mènent à l'illumination, le moine frappa dans un tas de sable. « Comptez, dit-il en souriant, et ajoutez d'autres grains. »"
    backgroundImage="/uploads/ministries-header-bg.webp"
  />

  <!-- Ministries Grid -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Un Dojo, plusieurs Voies</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Le dojo propose une variété de disciplines pour répondre aux besoins et aux intérêts de chacun. Que vous soyez débutant ou pratiquant avancé, vous trouverez une discipline qui vous convient.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {ministries.map(m => (
        <a
          href={`/disciplines/${m.slug}`}
          class="
          g-white rounded-lg shadow 
          flex flex-col overflow-hidden 
          hover:shadow-lg transition
          min-h-[370px]
          "
        >
            <!-- gambar fixed height 200px -->
            {m.data.logo && (
              <div class="w-full h-[200px] overflow-hidden">
                <img
                  src={m.data.logo}
                  alt={m.data.name}
                  class="w-full h-full object-cover"
                />
              </div>
            )}

            <div class="p-4 flex flex-col flex-1 justify-between">
              <div>
                <h3 class="text-xl font-semibold mb-2">{m.data.name}</h3>
                <p class="text-gray-700">{m.data.summary}</p>
              </div>
              {(m.data.coordinator || m.data.schedule) && (
                <div class="mt-4 space-y-1 text-sm text-gray-600">
                  {m.data.coordinator && (
                    <div class="flex items-center">
                      <svg xmlns="http://www.w3.org/2000/svg"
                           class="h-4 w-4 mr-1" fill="none"
                           viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              stroke-width="2"
                              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                      </svg>
                      Coordinator: {m.data.coordinator}
                    </div>
                  )}
                  {m.data.schedule && (
                    <div class="flex items-center">
                      <svg xmlns="http://www.w3.org/2000/svg"
                           class="h-4 w-4 mr-1 align-text-top" fill="none"
                           viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              stroke-width="2"
                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      {m.data.schedule}
                    </div>
                  )}
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section 
    class="py-20 bg-cover bg-center text-white"
    style="background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url(/uploads/ministries-header-bg.webp)"
  >
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6 text-white">Envie de nous rejoindre ?</h2>
        <p class="text-xl mb-8">
          Si vous êtes intéressé par nos activités ou si vous avez des questions, n'hésitez pas à nous contacter !
        </p>
        
        <div class="flex flex-wrap justify-center gap-4">
          <Button href="/im-new" variant="primary" size="lg">
            En savoir plus sur notre équipe
          </Button>
          
          <Button href="/contact" variant="outline" size="lg" class="bg-white/10 text-white border-white hover:bg-white hover:text-gray-900 backdrop-blur-sm">
            Nous contacter
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
