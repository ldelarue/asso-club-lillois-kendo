---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/Sections/HeroSection.astro";
import EventList from "../components/Sections/EventList.astro";
import SermonList from "../components/Sections/SermonList.astro";
import Button from "../components/UI/Button.astro";
---

<BaseLayout>
  <HeroSection 
    title="Les escrimes japonaises"
    subtitle="Une passion qui nous unit"
    backgroundImage="/uploads/hero-bg.webp"
    ctaText="Décrouvrir le Dojo"
    ctaLink="/about-us"
    secondaryCtaText="Explorer nos disciplines"
    secondaryCtaLink="/disciplines"
  />
    
  <!-- Events Section -->
  <EventList />

  <!-- Sermons Section -->
  <SermonList />

  <!-- Service Times -->
  <section class="py-16 bg-primary-50">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Horaires habituelles</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          <div class="bg-gray-50 p-8 rounded-lg shadow-sm">
            <h3 class="text-xl font-bold mb-3">Kendo</h3>
            <p class="text-2xl font-bold text-primary-600 mb-2">8:00 à 10:00</p>
            <p class="text-gray-600 mb-4">Lundis et mardis</p>
            <p class="italic text-gray-500">Salle habituelle</p>
          </div>
          
          <div class="bg-gray-50 p-8 rounded-lg shadow-sm">
            <h3 class="text-xl font-bold mb-3">Iaïdo</h3>
            <p class="text-2xl font-bold text-primary-600 mb-2">10:30 à 12:00</p>
            <p class="text-gray-600 mb-4">Mercredis et jeudis</p>
            <p class="italic text-gray-500">Salle habituelle</p>
          </div>
        </div>
        
        <Button href="/im-new" variant="outline">
          Décrouvrir le dojo
        </Button>
      </div>
    </div>
  </section>
  
  <!-- About Section -->
