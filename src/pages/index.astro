  <!-- Location Section -->
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Accès à la salle</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          La salle de sport de la gare Saint Sauveur vous accueille et est à disposition pour vos activités. Vous pouvez nous trouver facilement grâce aux indications ci-dessous.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div class="bg-gray-200 rounded-lg overflow-hidden h-96">
          <!-- Placeholder for Google Maps iframe -->
          <div class="w-full h-full flex items-center justify-center bg-gray-300">
            <p class="text-gray-600 text-center p-4">
              Map integration<br>
              <span class="text-sm">Je le ferai plus tard</span>
            </p>
          </div>
        </div>
        
        <div>
          <div class="bg-white p-8 rounded-lg shadow-md">
            <h3 class="text-xl font-bold mb-4">Quelques conseils</h3>
            
            <div class="space-y-6">
              <div>
                <h4 class="font-bold mb-2">Voiture</h4>
                <p class="text-gray-700">
                  Des parkings sont disponibles à proximité de la salle. Veuillez vérifier les panneaux de signalisation pour les restrictions de stationnement.
                </p>
              </div>
              
              <div>
                <h4 class="font-bold mb-2">Métro</h4>
                <p class="text-gray-700">
                  Ligne 2 (rouge) - Station "Lille Grand Palais", puis 5 minutes à pied<br>
                </p>
              </div>
              
              <div>
                <h4 class="font-bold mb-2">Accessibilité</h4>
                <p class="text-gray-700">
                  Le batiment est entièrement accessible aux personnes à mobilité réduite, avec des rampes et des ascenseurs disponibles.
                </p>
              </div>
            </div>
            
            <div class="mt-6">
              <Button href={siteData.contact.mapsUrl} target="_blank" variant="outline">
                Itinéraires
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
<!-- Newsletter Signup -->
  <section id="newsletter" class="py-16 bg-primary-50">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-4">Inscrivez-vous à notre newsletter</h2>
        <p class="text-lg text-gray-700 mb-8">
         Restez informé des dernières nouvelles, événements et mises à jour de notre dojo en recevant des informations directement dans votre boîte de réception.
        </p>
        
        <form id="newsletter-form" class="max-w-md mx-auto">
          <div class="flex flex-col sm:flex-row gap-4">
            <input 
              type="email" 
              id="newsletter-email" 
              placeholder="Votre adresse email" 
              required
              class="flex-grow px-4 py-3 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
            />
            
            <Button type="submit" variant="primary">
              S'abonner
            </Button>
          </div>
          <p class="text-sm text-gray-600 mt-3">
            Vous pouvez vous désinscire à tout moment.
          </p>
        </form>
        
        <script>
          // Handle newsletter form submission
          document.getElementById('newsletter-form')?.addEventListener('submit', function(e) {
            e.preventDefault();
            
            // In a real implementation, you would handle the form submission here
            // For this template, we'll just show a success message
            alert('Thank you for subscribing to our newsletter!');
            this.reset();
          });
        </script>
      </div>
    </div>
  </section>
  <JoinUs />
</BaseLayout>