---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroSection from "../components/Sections/HeroSection.astro";
import EventList from "../components/Sections/EventList.astro";
import Button from "../components/UI/Button.astro";
import JoinUs from "../components/Sections/JoinUs.astro";
import PostList from "../components/Sections/PostList.astro";
import siteData from "../content/siteData";
import conf from "../_data/conf.json";
// helper: split first word and the rest
const splitFirst = (text) => {
  if (!text) return { first: "", rest: "" };
  const trimmed = String(text).trim();
  const parts = trimmed.split(/\s+/);
  const first = parts.shift() || "";
  const rest = parts.join(" ");
  return { first, rest };
};
---

<BaseLayout>
  <HeroSection 
    title="Les escrimes japonaises"
    subtitle="Une passion qui nous unit"
    backgroundImage="/uploads/hero-bg.webp"
    ctaText="Décrouvrir le Dojo"
    ctaLink="/dojo"
    secondaryCtaText="Explorer nos disciplines"
    secondaryCtaLink="/disciplines"
  />
    
  <!-- Events Section -->
  <EventList />

  <!-- Post Section -->
  <PostList />

  <!-- Service Times -->
  <section class="py-16 bg-primary-50">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Horaires habituelles</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
          {conf.home.schedules.map((s) => (
            <div class="bg-gray-50 p-8 rounded-lg shadow-sm">
              <h3 class="text-xl font-bold mb-3">{s.section}</h3>
              {s.content.split('\n').map((line) => {
                const { first, rest } = splitFirst(line);
                return (
                  <div class="grid grid-cols-2 gap-4 items-start mb-2">
                    <div class="text-grey-600 font-medium">{first}</div>
                    <div class="text-xl font-bold text-primary-600">{rest}</div>
                  </div>
                );
              })}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
  
